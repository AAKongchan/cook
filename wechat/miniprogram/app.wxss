/**app.wxss**/
page {
  --primary-color: #FF6B9D;
  --primary-light: #FFB8D0;
  --primary-gradient-start: #FF8FB0;
  --primary-gradient-end: #C084FC;
  --bg-gradient: linear-gradient(180deg, #FFE4EC 0%, #FFF5F7 100%);
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #F0F0F0;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #FF4D4F;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: var(--bg-gradient);
  min-height: 100vh;
}

.container {
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.08);
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, var(--primary-gradient-start) 0%, var(--primary-gradient-end) 100%);
}

/* 粉色按钮 */
.btn-primary {
  background: linear-gradient(90deg, #FF8FB0 0%, #FF6B9D 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: var(--primary-color);
  color: #FFFFFF;
}

.tag-outline {
  background: #FFFFFF;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.tag-active {
  background: var(--primary-color);
  color: #FFFFFF;
}

/* 价格样式 */
.price {
  color: var(--primary-color);
  font-weight: 600;
}

.price::before {
  content: '¥';
  font-size: 0.8em;
}

/* 搜索框 */
.search-box {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-light);
}

/* 商品卡片 */
.goods-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.08);
}

.goods-image {
  width: 100%;
  height: 240rpx;
  object-fit: cover;
}

.goods-info {
  padding: 20rpx;
}

.goods-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn image {
  width: 28rpx;
  height: 28rpx;
}

/* 标签 */
.badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.badge-hot {
  background: #FF4D4F;
  color: #FFFFFF;
}

.badge-new {
  background: #52C41A;
  color: #FFFFFF;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 底部安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading {
  animation: spin 1s linear infinite;
}
