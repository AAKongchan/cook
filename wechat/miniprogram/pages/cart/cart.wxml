<view class="cart-container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-title">
      <view class="header-icon-wrap">
        <image class="cart-icon" src="/images/icons/icon-cart.svg" style="width: 48rpx; height: 48rpx;"/>
      </view>
      <text class="title">我的购物车</text>
    </view>
    <text class="subtitle" wx:if="{{cartList.length > 0}}">已选 {{selectedCount}} 件美食</text>
  </view>

  <!-- 滚动内容区域 -->
  <scroll-view class="scroll-content" scroll-y="true" wx:if="{{cartList.length > 0}}">
    <!-- 购物车列表 -->
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
        <image class="goods-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="goods-info">
          <view class="goods-main">
            <view class="goods-text">
              <text class="goods-name">{{item.name}}</text>
              <text class="goods-en">{{item.nameEn}}</text>
              <text class="goods-note" wx:if="{{item.note}}">备注：{{item.note}}</text>
            </view>
            <view class="goods-right">
              <text class="goods-price">¥{{item.price * item.quantity}}</text>
              <view class="quantity-control">
                <view class="btn-minus" bindtap="decrease" data-id="{{item.id}}">-</view>
                <text class="quantity">{{item.quantity}}</text>
                <view class="btn-plus" bindtap="increase" data-id="{{item.id}}">+</view>
              </view>
            </view>
          </view>
        <view class="goods-actions">
          <view class="action-btn note-action" bindtap="showNoteModal" data-item="{{item}}">
            <image class="action-icon" src="/images/icons/icon-note.svg" style="width: 28rpx; height: 28rpx; margin-right: 8rpx;"/>
            <text class="action-text">添加备注</text>
          </view>
          <view class="action-btn delete-action" bindtap="deleteItem" data-id="{{item.id}}">
            <image class="action-icon" src="/images/icons/icon-trash.svg" style="width: 28rpx; height: 28rpx; margin-right: 8rpx;"/>
            <text class="action-text">删除</text>
          </view>
        </view>
        </view>
      </view>
    </view>

    <!-- 订单明细 -->
    <view class="order-summary">
      <view class="summary-title">
        <view class="summary-icon-wrap">
          <image src="/images/icons/icon-clipboard.svg" style="width: 28rpx; height: 28rpx;"/>
        </view>
        <text>订单明细</text>
      </view>
      <view class="summary-item" wx:for="{{cartList}}" wx:key="id">
        <text>{{item.name}} x {{item.quantity}}</text>
        <text class="item-price">¥{{item.price * item.quantity}}</text>
      </view>
      <view class="summary-total">
        <text>合计</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
    </view>

    <!-- 确认下单按钮 -->
    <view class="submit-bar">
      <button class="submit-btn" bindtap="submitOrder">
        <image src="/images/icons/icon-check.svg" style="width: 32rpx; height: 32rpx; margin-right: 12rpx; filter: brightness(0) invert(1);"/>
        <text>确认下单 · ¥{{totalPrice}}</text>
      </button>
      <view class="clear-link" bindtap="clearCart">
        <image src="/images/icons/icon-trash.svg" style="width: 24rpx; height: 24rpx; margin-right: 8rpx;"/>
        <text>清空购物车</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-safe"></view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{cartList.length === 0}}">
    <view class="empty-icon-wrap">
      <image class="empty-icon" src="/images/icons/icon-cart.svg" mode="aspectFit"/>
    </view>
    <text class="empty-title">购物车空空如也</text>
    <text class="empty-desc">去选一些美味的食物吧～</text>
    <view class="empty-btn" bindtap="goToMenu">去点餐</view>
  </view>
</view>

<!-- 下单成功弹窗 -->
<view class="modal-mask" wx:if="{{showSuccessModal}}" bindtap="closeModal">
  <view class="modal-content" catchtap="preventClose">
    <view class="success-celebrate">
      <image class="celebrate-icon" src="/images/icons/icon-party.svg" mode="aspectFit"/>
    </view>
    <text class="modal-title">下单成功！</text>
    <text class="modal-desc">厨师小姐姐正在努力备餐中</text>
    <text class="modal-desc">请耐心等候约 15-20 分钟</text>
    <view class="modal-stars">
      <view class="star-item star-1"><image src="/images/icons/icon-heart.svg" mode="aspectFit"/></view>
      <view class="star-item star-2"><image src="/images/icons/icon-star.svg" mode="aspectFit"/></view>
      <view class="star-item star-3"><image src="/images/icons/icon-sparkle.svg" mode="aspectFit"/></view>
      <view class="star-item star-4"><image src="/images/icons/icon-star.svg" mode="aspectFit"/></view>
      <view class="star-item star-5"><image src="/images/icons/icon-heart.svg" mode="aspectFit"/></view>
    </view>
    <button class="modal-btn" bindtap="goHome">
      <text>太好了！回到菜单</text>
    </button>
  </view>
</view>

<!-- 备注弹窗 -->
<view class="note-modal-mask" wx:if="{{showNoteModal}}" bindtap="closeNoteModal">
  <view class="note-modal" catchtap="preventClose">
    <view class="note-modal-header">
      <image class="note-icon" src="/images/icons/icon-note.svg" style="width: 40rpx; height: 40rpx; margin-right: 16rpx;"/>
      <text class="note-title">为「{{selectedItem.name || '商品'}}」添加备注</text>
    </view>
    <textarea 
      class="note-textarea" 
      placeholder="例如：不加香菜、少辣、多放芝士..." 
      maxlength="100"
      bindinput="onNoteInput"
      value="{{noteText}}"
    />
    <text class="note-count">{{noteText.length}}/100</text>
    <view class="quick-tags">
      <text class="quick-title">快捷备注</text>
      <view class="tag-list">
        <text class="tag" wx:for="{{quickTags}}" wx:key="*this" bindtap="selectTag" data-tag="{{item}}">{{item}}</text>
      </view>
    </view>
    <view class="note-modal-footer">
      <view class="note-btn-cancel" bindtap="closeNoteModal">取消</view>
      <view class="note-btn-confirm" bindtap="saveNote">确定</view>
    </view>
  </view>
</view>
