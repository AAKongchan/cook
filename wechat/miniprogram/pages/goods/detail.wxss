.detail-container {
  min-height: 100vh;
  background: #FFFFFF;
}

.goods-image {
  width: 100%;
  height: 600rpx;
}

.goods-content {
  padding: 40rpx;
}

.goods-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.goods-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.goods-price {
  display: block;
  font-size: 48rpx;
  color: #FF6B9D;
  font-weight: 700;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.btn-cart, .btn-buy {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-cart {
  background: #FFE4EC;
  color: #FF6B9D;
  margin-right: 20rpx;
}

.btn-buy {
  background: linear-gradient(90deg, #FF8FB0 0%, #FF6B9D 100%);
  color: #FFFFFF;
}

.btn-cart::after, .btn-buy::after {
  border: none;
}
