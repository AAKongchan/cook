<view class="orders-container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-title">
      <text class="back" bindtap="goBack">←</text>
      <text class="title">历史订单</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="orders-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="orderNo">
      <view class="order-header">
        <view class="order-info">
          <text class="order-no">{{item.orderNo}}</text>
          <text class="order-date">{{item.date}}</text>
        </view>
        <view class="order-status {{item.status}}">
          <icon wx:if="{{item.status === 'completed'}}" name="checkmark" size="24" color="#52C41A"/>
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <view class="order-content">
        <text class="order-items">{{item.items}}</text>
        <view class="order-footer">
          <text class="order-price">¥{{item.price}}</text>
          <view class="reorder-btn" bindtap="reorder" data-order="{{item}}">
            <text>再来一单</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>