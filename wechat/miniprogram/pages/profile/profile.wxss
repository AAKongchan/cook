.profile-container {
  height: 100vh;
  background: linear-gradient(180deg, #FFD6E8 0%, #FFE2ED 30%, #FFEEF5 60%, #FFF5FA 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部固定区域 */
.header-fixed {
  flex-shrink: 0;
  z-index: 10;
}

/* 可滚动内容区域 */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

.header-bg {
  background: linear-gradient(135deg, #FFB6C1 0%, #E8E0FF 50%, #B8D4F0 100%);
  padding: 120rpx 40rpx 100rpx;
  border-radius: 0 0 50% 50% / 0 0 100rpx 100rpx;
  position: relative;
  margin-bottom: -60rpx;
  z-index: 1;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  background: #FFE4EC;
}

.edit-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #FF6B9D;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 2rpx solid #FFFFFF;
}

.user-detail {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 12rpx;
}

.clover {
  font-size: 28rpx;
}

.uid {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.vip-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.35);
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  backdrop-filter: blur(4rpx);
}

.star {
  margin-right: 8rpx;
  font-size: 20rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: -80rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B9D;
  margin-bottom: 8rpx;
}

.stat-value.price {
  color: #FF6B9D;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.trophy {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.unlock-info {
  font-size: 24rpx;
  color: #999;
}

.achievements {
  display: flex;
  justify-content: space-between;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.achv-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.achievement-item.unlocked .achv-icon {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFC1E3 100%);
}

.achievement-item.locked .achv-icon {
  background: #F5F5F5;
  opacity: 0.5;
}

.achv-name {
  font-size: 22rpx;
  color: #666;
}

.achievement-item.locked .achv-name {
  color: #999;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 30rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.badge-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.arrow {
  font-size: 32rpx;
  color: #CCC;
  transition: transform 0.3s;
}

.arrow-up {
  transform: rotate(180deg);
}

/* 历史订单列表 */
.order-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F5F5F5;
}

.order-item {
  background: #FFF8FA;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-no {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.order-date {
  font-size: 24rpx;
  color: #BBB;
}

.order-status {
  font-size: 24rpx;
  color: #52C41A;
  background: #E8F5E9;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.order-content {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin: 20rpx 0;
  line-height: 1.5;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.order-price {
  font-size: 36rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.reorder-btn {
  padding: 16rpx 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #FF6B9D;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #FF6B9D;
}

/* tabBar上方占位 */
.bottom-safe {
  height: 40rpx;
  background: transparent;
}

/* 收藏列表 */
.favorite-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F5F5F5;
}

.favorite-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

.favorite-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.favorite-item:last-child {
  border-bottom: none;
}

.favorite-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.favorite-info {
  flex: 1;
  min-width: 0;
}

.favorite-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.favorite-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-price {
  display: block;
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.favorite-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.favorite-star {
  width: 56rpx;
  height: 56rpx;
  background: #FFF8E7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-star .star-icon {
  font-size: 32rpx;
  color: #FFD700;
}

.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF8FB0 0%, #FF6B9D 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-cart-btn text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 300;
}

/* 品牌标语 */
.brand-slogan {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  margin: 40rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE8F0 50%, #FFE0EB 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.slogan-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 20rpx;
}

.slogan-text {
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 600;
  letter-spacing: 2rpx;
}
