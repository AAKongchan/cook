.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8E0FF 0%, #FFF0F5 25%, #FFFFFF 100%);
  padding-bottom: 120rpx;
}

.header-bg {
  background: linear-gradient(135deg, #C084FC 0%, #FF8FB0 100%);
  padding: 80rpx 40rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  background: #FFE4EC;
}

.edit-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #FF6B9D;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 2rpx solid #FFFFFF;
}

.user-detail {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 12rpx;
}

.clover {
  font-size: 28rpx;
}

.uid {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.vip-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
}

.star {
  margin-right: 8rpx;
  font-size: 20rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: -40rpx 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B9D;
  margin-bottom: 8rpx;
}

.stat-value.price {
  color: #FF6B9D;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.trophy {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.unlock-info {
  font-size: 24rpx;
  color: #999;
}

.achievements {
  display: flex;
  justify-content: space-between;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.achv-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.achievement-item.unlocked .achv-icon {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFC1E3 100%);
}

.achievement-item.locked .achv-icon {
  background: #F5F5F5;
  opacity: 0.5;
}

.achv-name {
  font-size: 22rpx;
  color: #666;
}

.achievement-item.locked .achv-name {
  color: #999;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 30rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.badge-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.arrow {
  font-size: 32rpx;
  color: #CCC;
}

.bottom-safe {
  height: 40rpx;
}
