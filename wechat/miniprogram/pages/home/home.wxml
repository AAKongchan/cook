<view class="home-container">
  <!-- 顶部固定区域 -->
  <view class="header-fixed">
    <!-- 顶部渐变背景 -->
    <view class="header-bg">
      <!-- Logo 区域 -->
      <view class="logo-section">
        <image class="logo-icon" src="/images/icons/icon-chefhat.svg" style="width: 72rpx; height: 72rpx; margin-right: 20rpx;"/>
        <view class="logo-content">
          <view class="logo-text">
            <text class="welcome">欢迎来到</text>
            <text class="brand">精品厨房</text>
            <text class="star-icon">✨</text>
          </view>
          <text class="slogan">新鲜美味 · 用心制作 · 每日精选</text>
        </view>
      </view>
      
      <!-- 搜索框 -->
      <view class="search-box">
        <image class="search-icon" src="/images/icons/icon-search.svg" mode="aspectFit"/>
        <input class="search-input" placeholder="搜索你想吃的..." placeholder-class="search-placeholder" bindinput="onSearchInput" value="{{searchKeyword}}"/>
      </view>
    </view>

    <!-- 分类标签 -->
    <view class="category-section">
      <!-- 全部按钮固定 -->
      <view class="tab tab-all {{currentTab === 0 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="0">
        <text class="tab-emoji">✨</text>
        <text>全部</text>
      </view>
      <!-- 其他分类可滑动 -->
      <scroll-view class="category-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view 
          class="tab {{currentTab === index + 1 ? 'tab-active' : ''}} {{index === categories.length - 2 ? 'tab-last' : ''}}" 
          wx:for="{{categories}}" 
          wx:key="*this"
          wx:if="{{index > 0 && index < categories.length - 1}}"
          bindtap="switchTab" 
          data-index="{{index + 1}}"
        >
          <text class="tab-emoji">
            <text wx:if="{{item === '肉菜'}}">🥩</text>
            <text wx:if="{{item === '素菜'}}">🥬</text>
            <text wx:if="{{item === '汤菜'}}">🍵</text>
            <text wx:if="{{item === '炖菜'}}">🍲</text>
            <text wx:if="{{item === '凉菜'}}">🧊</text>
            <text wx:if="{{item === '沙拉'}}">🥗</text>
          </text>
          <text>{{item}}</text>
        </view>
        <!-- 我的收藏 -->
        <view class="tab {{currentTab === categories.length - 1 ? 'tab-active' : ''}} tab-last" bindtap="switchTab" data-index="{{categories.length - 1}}">
          <text class="tab-emoji">⭐</text>
          <text>我的收藏</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 可滚动内容区域 -->
  <scroll-view class="content-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <!-- 限时优惠横幅 -->
    <view class="promo-banner" wx:if="{{currentTab === 0}}">
      <view class="promo-content">
        <image class="promo-icon" src="/images/icons/icon-party.svg" style="width: 80rpx; height: 80rpx; margin-right: 30rpx;"/>
        <view class="promo-text">
          <text class="promo-title">限时优惠！</text>
          <text class="promo-desc">满¥100享9折，满¥200享8折</text>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="goods-list">
      <view class="goods-item" wx:for="{{goodsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="goods-image-wrap">
          <image class="goods-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="badge badge-hot" wx:if="{{item.isHot}}">招牌</view>
          <view class="badge badge-new" wx:if="{{item.isNew}}">新品</view>
          <view class="favorite-btn {{item.isFavorite ? 'favorite-active' : ''}}" catchtap="toggleFavorite" data-item="{{item}}">
            <text class="favorite-icon">{{item.isFavorite ? '★' : '☆'}}</text>
          </view>
        </view>
        <view class="goods-info">
          <text class="goods-title">{{item.name}}</text>
          <text class="goods-desc">{{item.description}}</text>
          <view class="goods-price-row">
            <text class="goods-price">¥{{item.price}}</text>
            <view class="add-btn" catchtap="addToCart" data-item="{{item}}">
              <text class="add-icon">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
</view>
